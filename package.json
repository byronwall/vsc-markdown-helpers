{
    "name": "vsc-md-helpers",
    "displayName": "Markdown Helpers",
    "description": "Workspace markdown preview plus code-view helpers for file links, code blocks, and bounded wrapping",
    "version": "0.0.2",
    "publisher": "byronwall",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/byronwall/vsc-md-helpers.git"
    },
    "homepage": "https://github.com/byronwall/vsc-md-helpers",
    "bugs": {
        "url": "https://github.com/byronwall/vsc-md-helpers/issues"
    },
    "icon": "assets/icon.png",
    "galleryBanner": {
        "color": "#18333A",
        "theme": "dark"
    },
    "keywords": [
        "markdown",
        "preview",
        "links",
        "code-blocks",
        "mermaid",
        "documentation",
        "workspace"
    ],
    "pricing": "Free",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:markdown"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "markdownHelpers.refresh",
                "category": "Markdown Helpers",
                "title": "Refresh Recent Markdown",
                "icon": "$(refresh)"
            },
            {
                "command": "markdownHelpers.showOutput",
                "category": "Markdown Helpers",
                "title": "Show Output",
                "icon": "$(output)"
            },
            {
                "command": "markdownHelpers.enableRecentFilesPrFilter",
                "category": "Markdown Helpers",
                "title": "Show Changed Markdown",
                "icon": "$(filter)"
            },
            {
                "command": "markdownHelpers.disableRecentFilesPrFilter",
                "category": "Markdown Helpers",
                "title": "Show All Markdown",
                "icon": "$(list-unordered)"
            },
            {
                "command": "markdownHelpers.openMarkdown",
                "category": "Markdown Helpers",
                "title": "Open Preview",
                "icon": "$(preview)"
            },
            {
                "command": "markdownHelpers.openMarkdownFile",
                "category": "Markdown Helpers",
                "title": "Open Markdown File",
                "icon": "$(go-to-file)"
            },
            {
                "command": "markdownHelpers.copyMarkdownPath",
                "category": "Markdown Helpers",
                "title": "Copy Markdown Full Path",
                "icon": "$(copy)"
            },
            {
                "command": "markdownHelpers.revealPreview",
                "category": "Markdown Helpers",
                "title": "Reveal Preview",
                "icon": "$(preview)"
            },
            {
                "command": "markdownHelpers.openLocation",
                "category": "Markdown Helpers",
                "title": "Open Link Target",
                "icon": "$(go-to-file)"
            },
            {
                "command": "markdownHelpers.openCodeBlock",
                "category": "Markdown Helpers",
                "title": "Open Code Block",
                "icon": "$(code)"
            },
            {
                "command": "markdownHelpers.openCodeBlockAtCursor",
                "category": "Markdown Helpers",
                "title": "Open Code Block At Cursor",
                "icon": "$(code)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "markdownHelpers",
                    "title": "Markdown",
                    "icon": "$(markdown)"
                }
            ]
        },
        "views": {
            "markdownHelpers": [
                {
                    "id": "markdownHelpers.recentMarkdown",
                    "name": "Recent Markdown"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "markdownHelpers.enableRecentFilesPrFilter",
                    "when": "view == markdownHelpers.recentMarkdown && !markdownHelpers.recentMarkdownPrFilterEnabled",
                    "group": "navigation@1"
                },
                {
                    "command": "markdownHelpers.disableRecentFilesPrFilter",
                    "when": "view == markdownHelpers.recentMarkdown && markdownHelpers.recentMarkdownPrFilterEnabled",
                    "group": "navigation@1"
                },
                {
                    "command": "markdownHelpers.refresh",
                    "when": "view == markdownHelpers.recentMarkdown",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "markdownHelpers.openMarkdownFile",
                    "when": "view == markdownHelpers.recentMarkdown && viewItem == markdownFile",
                    "group": "inline@1"
                },
                {
                    "command": "markdownHelpers.copyMarkdownPath",
                    "when": "view == markdownHelpers.recentMarkdown && viewItem == markdownFile",
                    "group": "inline@2"
                }
            ],
            "editor/title": [
                {
                    "command": "markdownHelpers.openMarkdown",
                    "when": "resourceLangId == markdown || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
                    "group": "navigation@1"
                }
            ]
        },
        "configuration": {
            "title": "Markdown Helpers",
            "properties": {
                "markdownHelpers.maxRecent": {
                    "type": "number",
                    "default": 60,
                    "minimum": 5,
                    "maximum": 500,
                    "description": "Maximum number of markdown files shown in the Recent Markdown tree."
                },
                "markdownHelpers.extensions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ".md",
                        ".markdown",
                        ".mdx"
                    ],
                    "description": "File extensions treated as markdown files for discovery."
                },
                "markdownHelpers.previewMaxWidth": {
                    "type": "number",
                    "default": 96,
                    "minimum": 48,
                    "maximum": 180,
                    "description": "Maximum rendered markdown content width, in characters, inside the preview panel."
                },
                "markdownHelpers.recentFilesFilter": {
                    "type": "string",
                    "enum": [
                        "all",
                        "changedSinceBase"
                    ],
                    "default": "all",
                    "description": "Filter the Recent Markdown tree to either all discovered markdown files or only files changed on the current branch relative to the configured base ref, including local staged, unstaged, and untracked changes."
                },
                "markdownHelpers.recentFilesBaseRef": {
                    "type": "string",
                    "default": "main",
                    "description": "Git base ref used when recentFilesFilter is changedSinceBase. Examples: main, origin/main, upstream/main."
                }
            }
        },
        "configurationDefaults": {
            "[markdown]": {
                "editor.wordWrap": "bounded",
                "editor.wordWrapColumn": 96
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --outfile=out/extension.js",
        "bundle:webview": "esbuild media/src/viewer.entry.js --bundle --format=esm --platform=browser --minify --legal-comments=none --outfile=media/dist/viewer.bundle.js",
        "typecheck": "tsc -p ./ --noEmit",
        "compile": "pnpm run typecheck && pnpm run bundle:extension && pnpm run bundle:webview",
        "watch": "tsc -watch -p ./",
        "package:vsix": "pnpm run compile && vsce package --no-dependencies -o vsc-md-helpers.vsix",
        "publish:vsix": "vsce publish --packagePath vsc-md-helpers.vsix",
        "publish:patch": "pnpm run compile && vsce publish patch --no-dependencies",
        "publish:minor": "pnpm run compile && vsce publish minor --no-dependencies",
        "install:vsix": "code --install-extension vsc-md-helpers.vsix --force",
        "build:install": "pnpm run package:vsix && pnpm run install:vsix",
        "dev:host": "code --extensionDevelopmentPath=$PWD $PWD"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^22.10.1",
        "@types/vscode": "^1.95.0",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.4",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "gray-matter": "^4.0.3",
        "highlight.js": "^11.11.1",
        "markdown-it": "^14.1.1",
        "markdown-it-anchor": "^9.2.0",
        "mermaid": "^11.13.0",
        "svg-pan-zoom": "^3.6.2"
    }
}
